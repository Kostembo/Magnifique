# Скопировать в /var/www/magnifique/.env.production.local на сервере

# PostgreSQL на VPS (после db_setup.sh)
DATABASE_URL="postgresql://magnifique_user:STRONG_PASSWORD@localhost:5432/magnifique"
DIRECT_URL="postgresql://magnifique_user:STRONG_PASSWORD@localhost:5432/magnifique"

# Сгенерировать: openssl rand -base64 32
AUTH_SECRET="GENERATE_ME"

# Ваш домен
NEXTAUTH_URL="https://YOUR_DOMAIN.ru"

# Сгенерировать: openssl rand -hex 32
PASSPORT_ENCRYPTION_KEY="GENERATE_ME_64_HEX_CHARS"

# VAPID-ключи (те же что в .env.local или новые: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"
VAPID_SUBJECT="mailto:admin@YOUR_DOMAIN.ru"
