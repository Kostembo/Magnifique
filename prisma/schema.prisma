generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  waiter
  cook
  warehouse
  manager
  sales
  chef
  owner
  admin
  accountant
}

enum Tier {
  core
  regular
  trainee
}

enum EventStatus {
  draft
  recruiting
  staffed
  done
}

enum AssignmentStatus {
  invited
  confirmed
  declined
  expired
  waitlisted
}

enum RequisitionStatus {
  draft
  sent
  picking
  done
}

enum PayStatus {
  draft
  confirmed
  paid
}

model Employee {
  id                String    @id @default(cuid())
  full_name         String
  phone             String    @unique
  password_hash     String
  role              Role
  tier              Tier      @default(regular)
  passport_data_enc String?
  photo_url         String?
  push_subscription Json?
  created_at        DateTime  @default(now())

  // Зарплата
  hourly_rate       Decimal?  @db.Decimal(10, 2)
  min_pay_amount    Decimal?  @db.Decimal(10, 2)
  min_pay_hours     Int?

  created_events    Event[]        @relation("CreatedEvents")
  assignments       Assignment[]
  requisitions      Requisition[]  @relation("AssignedRequisitions")
  comments          Comment[]
  time_entries      TimeEntry[]

  @@map("employees")
}

model Event {
  id           String      @id @default(cuid())
  title        String
  client       String?
  location     String?
  guests_count Int?
  starts_at    DateTime
  status       EventStatus @default(draft)
  created_by   String
  created_at   DateTime    @default(now())

  // Времена прибытия
  warehouse_time DateTime?
  venue_time     DateTime?

  creator      Employee        @relation("CreatedEvents", fields: [created_by], references: [id])
  positions    EventPosition[]
  assignments  Assignment[]
  requisitions Requisition[]
  comments     Comment[]
  time_entries TimeEntry[]
  event_menu   EventMenuItem[]

  @@map("events")
}

model EventPosition {
  id                Int      @id @default(autoincrement())
  event_id          String
  role              Role
  needed_count      Int
  reserved_for_core Int      @default(0)
  priority_deadline DateTime?

  event       Event        @relation(fields: [event_id], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@map("event_positions")
}

model Assignment {
  id           String           @id @default(cuid())
  event_id     String
  position_id  Int
  employee_id  String
  status       AssignmentStatus @default(invited)
  is_priority  Boolean          @default(false)
  invited_at   DateTime         @default(now())
  responded_at DateTime?

  // Логистика смены
  goes_to_warehouse Boolean   @default(false)
  scheduled_time    DateTime?

  event    Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  position EventPosition @relation(fields: [position_id], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employee_id], references: [id])

  @@unique([position_id, employee_id])
  @@map("assignments")
}

model Requisition {
  id          String            @id @default(cuid())
  event_id    String
  status      RequisitionStatus @default(draft)
  assignee_id String?
  sent_at     DateTime?
  created_at  DateTime          @default(now())

  event    Event              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  assignee Employee?          @relation("AssignedRequisitions", fields: [assignee_id], references: [id])
  items    RequisitionItem[]

  @@map("requisitions")
}

model RequisitionItem {
  id             Int     @id @default(autoincrement())
  requisition_id String
  name           String
  quantity       Decimal @db.Decimal(10, 2)
  unit           String  @default("шт")
  is_picked      Boolean @default(false)

  requisition Requisition @relation(fields: [requisition_id], references: [id], onDelete: Cascade)

  @@map("requisition_items")
}

model TimeEntry {
  id          String    @id @default(cuid())
  employee_id String
  event_id    String
  work_date   DateTime  @db.Date

  // Ручные/скорректированные значения (HH:mm)
  start_time  String?
  end_time    String?

  // Авто-фиксация (raw timestamps)
  checked_in_at  DateTime?
  checked_out_at DateTime?
  is_offline     Boolean   @default(false)

  // Расчёт зарплаты
  calculated_hours Decimal?  @db.Decimal(10, 2)
  calculated_pay   Decimal?  @db.Decimal(10, 2)
  pay_status       PayStatus @default(draft)
  pay_comment      String?

  created_at DateTime @default(now())

  employee Employee @relation(fields: [employee_id], references: [id])
  event    Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, event_id])
  @@map("time_entries")
}

model Comment {
  id         String   @id @default(cuid())
  event_id   String
  author_id  String
  body       String
  created_at DateTime @default(now())

  event  Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  author Employee @relation(fields: [author_id], references: [id])

  @@map("comments")
}

model MenuItem {
  id         Int      @id @default(autoincrement())
  name       String
  category   String   @default("")
  unit       String   @default("порц")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  event_menu EventMenuItem[]

  @@map("menu_items")
}

model EventMenuItem {
  id           Int      @id @default(autoincrement())
  event_id     String
  menu_item_id Int?
  name         String
  quantity     Decimal  @db.Decimal(10, 2)
  unit         String   @default("порц")
  note         String?
  created_at   DateTime @default(now())

  event     Event      @relation(fields: [event_id], references: [id], onDelete: Cascade)
  menu_item MenuItem?  @relation(fields: [menu_item_id], references: [id])

  @@map("event_menu_items")
}

model WarehouseItem {
  id         Int      @id @default(autoincrement())
  name       String
  unit       String   @default("шт")
  category   String   @default("")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("warehouse_items")
}
