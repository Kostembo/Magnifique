# PostgreSQL (российское облако — Timeweb/Yandex Cloud/Selectel)
DATABASE_URL="postgresql://user:password@localhost:5432/magnifique"

# NextAuth — сгенерировать: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Шифрование passport_data — сгенерировать: openssl rand -hex 32 (64 символа hex = 32 байта)
PASSPORT_ENCRYPTION_KEY="your-32-byte-hex-key-here-64chars"

# VAPID-ключи для Web Push
# Генерация: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@magnifique.ru"
